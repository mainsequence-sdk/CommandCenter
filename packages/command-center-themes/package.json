{
  "name": "@dev-mainsequence/command-center-themes",
  "version": "0.1.3",
  "private": false,
  "description": "Shared Command Center theme presets, token contracts, and theme application helpers.",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/mainsequence-sdk/CommandCenter.git",
    "directory": "packages/command-center-themes"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "ag-grid.css",
    "fonts.css",
    "markdown.css",
    "react-flow.css",
    "react-grid-layout.css",
    "styles.css",
    "tailwind.css",
    "utilities.css",
    "README.md"
  ],
  "style": "./styles.css",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./data-viz": {
      "types": "./dist/chart-palettes.d.ts",
      "import": "./dist/chart-palettes.js"
    },
    "./presets": {
      "types": "./dist/presets/index.d.ts",
      "import": "./dist/presets/index.js"
    },
    "./ag-grid.css": "./ag-grid.css",
    "./fonts.css": "./fonts.css",
    "./markdown.css": "./markdown.css",
    "./react-flow.css": "./react-flow.css",
    "./react-grid-layout.css": "./react-grid-layout.css",
    "./styles.css": "./styles.css",
    "./tailwind.css": "./tailwind.css",
    "./utilities.css": "./utilities.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
