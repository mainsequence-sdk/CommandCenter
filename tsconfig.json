{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@mainsequence/command-center-themes": ["packages/command-center-themes/src/index.ts"],
      "@mainsequence/command-center-themes/data-viz": [
        "packages/command-center-themes/src/chart-palettes.ts"
      ],
      "@mainsequence/command-center-themes/presets": [
        "packages/command-center-themes/src/presets/index.ts"
      ],
      "@mainsequence/command-center-themes/*": ["packages/command-center-themes/src/*"],
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "extensions", "connections", "packages/command-center-themes/src", "vite.config.ts"]
}
